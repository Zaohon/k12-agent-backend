generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Organization {
  id          Int       @id @default(autoincrement())
  orgName     String    @unique(map: "uk_lq_organization_org_name") @map("org_name")
  contactInfo String?   @map("contact_info")
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  users  User[]
  agents Agent[]
  categories Category[]
  knowledgeFolders KnowledgeFolder[]
  knowledgeFiles   KnowledgeFile[]
  modelConfigs     ModelConfig[]

  @@index([status], map: "idx_lq_organization_status")
  @@index([createdAt], map: "idx_lq_organization_created_at")
  @@index([updatedAt], map: "idx_lq_organization_updated_at")
  @@index([deletedAt], map: "idx_lq_organization_deleted_at")
  @@map("lq_organization")
}

model User {
  id            Int       @id @default(autoincrement())
  username      String    @unique(map: "uk_lq_user_username")
  phone         String?   @unique(map: "uk_lq_user_phone") @db.VarChar(20)
  passwordHash  String?   @map("password_hash") @db.VarChar(255)
  passwordSetAt DateTime? @map("password_set_at")
  role          String    @default("TEACHER") @db.VarChar(50)
  orgId         Int?      @map("org_id")
  tokenLimit    Int       @default(50000) @map("token_limit")
  consumedToken Int       @default(0) @map("consumed_token")
  status        String    @default("ACTIVE") @db.VarChar(32)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  organization  Organization? @relation(fields: [orgId], references: [id])
  createdAgents Agent[]
  conversations Conversation[]
  knowledgeFolders KnowledgeFolder[]
  knowledgeFiles   KnowledgeFile[]

  @@index([orgId], map: "idx_lq_user_org_id")
  @@index([phone], map: "idx_lq_user_phone")
  @@index([role], map: "idx_lq_user_role")
  @@index([status], map: "idx_lq_user_status")
  @@index([passwordSetAt], map: "idx_lq_user_password_set_at")
  @@index([createdAt], map: "idx_lq_user_created_at")
  @@index([updatedAt], map: "idx_lq_user_updated_at")
  @@index([deletedAt], map: "idx_lq_user_deleted_at")
  @@map("lq_user")
}

model Agent {
  id             Int       @id @default(autoincrement())
  title          String    @db.VarChar(255)
  description    String?   @db.Text
  iconUrl        String?   @map("icon_url") @db.VarChar(500)
  systemPrompt   String    @map("system_prompt") @db.LongText
  welcomeMsg     String?   @map("welcome_msg") @db.Text
  formConfig     String?   @map("form_config") @db.LongText
  model          String    @default("deepseek-v4-flash") @db.VarChar(100)
  enableWebSearch Boolean  @default(false) @map("enable_web_search")
  enableWebParse  Boolean  @default(false) @map("enable_web_parse")
  enableDeepThink Boolean  @default(false) @map("enable_deep_think")
  enableFileUpload Boolean @default(false) @map("enable_file_upload")
  enableKnowledgeBase Boolean @default(false) @map("enable_knowledge_base")
  creatorId      Int       @map("creator_id")
  orgId          Int?      @map("org_id")
  visibility     String    @default("PRIVATE") @db.VarChar(32)
  approvalStatus String    @default("APPROVED") @map("approval_status") @db.VarChar(32)
  isFeatured     Boolean   @default(false) @map("is_featured")
  status         String    @default("ACTIVE") @db.VarChar(32)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  creator       User          @relation(fields: [creatorId], references: [id])
  organization  Organization? @relation(fields: [orgId], references: [id])
  conversations Conversation[]
  categories    AgentCategory[]

  @@index([creatorId], map: "idx_lq_agent_creator_id")
  @@index([orgId], map: "idx_lq_agent_org_id")
  @@index([visibility], map: "idx_lq_agent_visibility")
  @@index([model], map: "idx_lq_agent_model")
  @@index([approvalStatus], map: "idx_lq_agent_approval_status")
  @@index([isFeatured], map: "idx_lq_agent_is_featured")
  @@index([status], map: "idx_lq_agent_status")
  @@index([createdAt], map: "idx_lq_agent_created_at")
  @@index([updatedAt], map: "idx_lq_agent_updated_at")
  @@index([deletedAt], map: "idx_lq_agent_deleted_at")
  @@map("lq_agent")
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(100)
  parentId  Int?      @map("parent_id")
  orgId     Int?      @map("org_id")
  weight    Int       @default(0)
  status    String    @default("ACTIVE") @db.VarChar(32)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  organization Organization? @relation(fields: [orgId], references: [id])
  agents AgentCategory[]

  @@index([parentId], map: "idx_lq_category_parent_id")
  @@index([orgId], map: "idx_lq_category_org_id")
  @@index([status], map: "idx_lq_category_status")
  @@index([weight], map: "idx_lq_category_weight")
  @@index([createdAt], map: "idx_lq_category_created_at")
  @@index([updatedAt], map: "idx_lq_category_updated_at")
  @@index([deletedAt], map: "idx_lq_category_deleted_at")
  @@map("lq_category")
}

model AgentCategory {
  id         Int       @id @default(autoincrement())
  agentId    Int       @map("agent_id")
  categoryId Int       @map("category_id")
  status     String    @default("ACTIVE") @db.VarChar(32)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  agent    Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([agentId, categoryId], map: "uk_lq_agent_category_agent_id_category_id")
  @@index([agentId], map: "idx_lq_agent_category_agent_id")
  @@index([categoryId], map: "idx_lq_agent_category_category_id")
  @@index([status], map: "idx_lq_agent_category_status")
  @@index([createdAt], map: "idx_lq_agent_category_created_at")
  @@index([updatedAt], map: "idx_lq_agent_category_updated_at")
  @@index([deletedAt], map: "idx_lq_agent_category_deleted_at")
  @@map("lq_agent_category")
}

model Conversation {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  agentId   Int?      @map("agent_id")
  topic     String?   @db.VarChar(255)
  isDeleted Boolean   @default(false) @map("is_deleted")
  status    String    @default("ACTIVE") @db.VarChar(32)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user     User     @relation(fields: [userId], references: [id])
  agent    Agent?   @relation(fields: [agentId], references: [id])
  messages Message[]

  @@index([userId], map: "idx_lq_conversation_user_id")
  @@index([agentId], map: "idx_lq_conversation_agent_id")
  @@index([isDeleted], map: "idx_lq_conversation_is_deleted")
  @@index([status], map: "idx_lq_conversation_status")
  @@index([createdAt], map: "idx_lq_conversation_created_at")
  @@index([updatedAt], map: "idx_lq_conversation_updated_at")
  @@index([deletedAt], map: "idx_lq_conversation_deleted_at")
  @@map("lq_conversation")
}

model Message {
  id               Int       @id @default(autoincrement())
  convId           Int       @map("conversation_id")
  role             String    @db.VarChar(32)
  content          String    @db.LongText
  promptTokens     Int       @default(0) @map("prompt_tokens")
  completionTokens Int       @default(0) @map("completion_tokens")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  conversation Conversation @relation(fields: [convId], references: [id], onDelete: Cascade)

  @@index([convId], map: "idx_lq_message_conversation_id")
  @@index([role], map: "idx_lq_message_role")
  @@index([createdAt], map: "idx_lq_message_created_at")
  @@index([updatedAt], map: "idx_lq_message_updated_at")
  @@index([deletedAt], map: "idx_lq_message_deleted_at")
  @@map("lq_message")
}

model KnowledgeFolder {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(120)
  parentId  Int?      @map("parent_id")
  ownerId   Int       @map("owner_id")
  orgId     Int?      @map("org_id")
  status    String    @default("ACTIVE") @db.VarChar(32)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  parent   KnowledgeFolder?  @relation("KnowledgeFolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children KnowledgeFolder[] @relation("KnowledgeFolderTree")
  owner    User              @relation(fields: [ownerId], references: [id])
  organization Organization? @relation(fields: [orgId], references: [id])
  files    KnowledgeFile[]

  @@index([parentId], map: "idx_lq_knowledge_folder_parent_id")
  @@index([ownerId], map: "idx_lq_knowledge_folder_owner_id")
  @@index([orgId], map: "idx_lq_knowledge_folder_org_id")
  @@index([status], map: "idx_lq_knowledge_folder_status")
  @@index([createdAt], map: "idx_lq_knowledge_folder_created_at")
  @@index([updatedAt], map: "idx_lq_knowledge_folder_updated_at")
  @@index([deletedAt], map: "idx_lq_knowledge_folder_deleted_at")
  @@map("lq_knowledge_folder")
}

model KnowledgeFile {
  id         Int       @id @default(autoincrement())
  folderId   Int?      @map("folder_id")
  ownerId    Int       @map("owner_id")
  orgId      Int?      @map("org_id")
  name       String    @db.VarChar(255)
  ext        String?   @db.VarChar(32)
  mimeType   String?   @map("mime_type") @db.VarChar(120)
  size       Int       @default(0)
  ossKey     String    @map("oss_key") @db.VarChar(500)
  url        String?   @db.VarChar(1000)
  status     String    @default("UPLOADED") @db.VarChar(32)
  parseStatus String   @default("PENDING") @map("parse_status") @db.VarChar(32)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  folder       KnowledgeFolder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
  owner        User               @relation(fields: [ownerId], references: [id])
  organization Organization?      @relation(fields: [orgId], references: [id])
  jobs         KnowledgeFileJob[]

  @@index([folderId], map: "idx_lq_knowledge_file_folder_id")
  @@index([ownerId], map: "idx_lq_knowledge_file_owner_id")
  @@index([orgId], map: "idx_lq_knowledge_file_org_id")
  @@index([status], map: "idx_lq_knowledge_file_status")
  @@index([parseStatus], map: "idx_lq_knowledge_file_parse_status")
  @@index([createdAt], map: "idx_lq_knowledge_file_created_at")
  @@index([updatedAt], map: "idx_lq_knowledge_file_updated_at")
  @@index([deletedAt], map: "idx_lq_knowledge_file_deleted_at")
  @@index([name], map: "idx_lq_knowledge_file_name")
  @@map("lq_knowledge_file")
}

model KnowledgeFileJob {
  id           Int       @id @default(autoincrement())
  fileId       Int       @map("file_id")
  jobType      String    @default("PARSE") @map("job_type") @db.VarChar(32)
  status       String    @default("PENDING") @db.VarChar(32)
  errorMessage String?   @map("error_message") @db.VarChar(1000)
  startedAt    DateTime? @map("started_at")
  finishedAt   DateTime? @map("finished_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  file KnowledgeFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId], map: "idx_lq_knowledge_file_job_file_id")
  @@index([jobType], map: "idx_lq_knowledge_file_job_job_type")
  @@index([status], map: "idx_lq_knowledge_file_job_status")
  @@index([createdAt], map: "idx_lq_knowledge_file_job_created_at")
  @@index([updatedAt], map: "idx_lq_knowledge_file_job_updated_at")
  @@map("lq_knowledge_file_job")
}

model ModelConfig {
  id                  Int       @id @default(autoincrement())
  orgId               Int?      @map("org_id")
  isDefault           Boolean   @default(false) @map("is_default")
  defaultModel        String    @default("qwen3.6-plus") @map("default_model") @db.VarChar(100)
  apiBaseUrl          String    @map("api_base_url") @db.VarChar(500)
  apiKey              String?   @map("api_key") @db.VarChar(500)
  orgMaxTokenLimit    Int       @default(4096) @map("org_max_token_limit")
  requestTimeout      Int       @default(60) @map("request_timeout")
  enableContextMemory Boolean   @default(false) @map("enable_context_memory")
  status              String    @default("ACTIVE") @db.VarChar(32)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  organization        Organization? @relation(fields: [orgId], references: [id])

  @@unique([orgId, isDefault], map: "uk_lq_model_config_org_id_is_default")
  @@index([orgId], map: "idx_lq_model_config_org_id")
  @@index([isDefault], map: "idx_lq_model_config_is_default")
  @@index([status], map: "idx_lq_model_config_status")
  @@index([createdAt], map: "idx_lq_model_config_created_at")
  @@index([updatedAt], map: "idx_lq_model_config_updated_at")
  @@index([deletedAt], map: "idx_lq_model_config_deleted_at")
  @@map("lq_model_config")
}
